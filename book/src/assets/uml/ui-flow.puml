@startuml
title UI And Data Flow
skinparam backgroundColor transparent
skinparam shadowing false
skinparam dpi 180
skinparam defaultFontName Helvetica
skinparam ArrowColor #475569
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam rectangle {
  BorderColor #0F172A
  BackgroundColor #FFFFFF
}
skinparam package {
  BorderColor #94A3B8
  BackgroundColor #F8FAFC
}
skinparam linetype polyline
left to right direction

package "Navigation" {
  rectangle MainActivity
}

package "Fragments" {
  rectangle SimulationFragment
  rectangle StatsFragment
  rectangle SaveLoadFragment
  rectangle SettingsFragment
}

package "UI Views / Adapters" {
  rectangle SimulationCanvasView
  rectangle TextureLibrary
  rectangle SaveAdapter
}

package "Shared Runtime" {
  rectangle SimulationSession
  rectangle SimulationEngine
  rectangle StatTracker
  rectangle AppSettings
  rectangle MusicManager
  rectangle SimulationStorage
}

MainActivity --> SimulationFragment : opens
MainActivity --> StatsFragment : opens
MainActivity --> SaveLoadFragment : opens
MainActivity --> SettingsFragment : opens

SimulationFragment --> SimulationCanvasView : renders world
SimulationFragment --> SimulationSession : active session
SimulationFragment --> SimulationEngine : listens / commands
SimulationFragment --> AppSettings : reads UI prefs

StatsFragment --> SimulationEngine : subscribes
StatsFragment --> StatTracker : reads history

SaveLoadFragment --> SimulationSession : load into session
SaveLoadFragment --> SimulationStorage : CRUD saves
SaveLoadFragment --> SaveAdapter : RecyclerView rows

SettingsFragment --> AppSettings : edits defaults
SettingsFragment --> SimulationSession : regenerates world
SettingsFragment --> SimulationStorage : cleanup

SimulationCanvasView --> TextureLibrary : sprites
MusicManager --> AppSettings : listens

SimulationFragment -[hidden]-> StatsFragment
StatsFragment -[hidden]-> SaveLoadFragment
SaveLoadFragment -[hidden]-> SettingsFragment
SimulationCanvasView -[hidden]-> SaveAdapter
SimulationEngine -[hidden]-> SimulationStorage
@enduml
