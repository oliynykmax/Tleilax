<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tleilax / Dune Theme -->
    <style name="Base.Theme.Tleilax" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="colorPrimary">@color/accent_gold</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorSecondary">@color/accent_gold_bright</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Default UI Components -->
        <item name="materialButtonStyle">@style/Widget.Tleilax.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.Tleilax.BottomNavigation</item>
        <item name="navigationRailStyle">@style/Widget.Tleilax.BottomNavigation</item>
    </style>

    <style name="Theme.Tleilax" parent="Base.Theme.Tleilax" />

    <!-- Primary Button - Outlined with subtle spice gold -->
    <style name="Widget.Tleilax.Button" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="rippleColor">@color/accent_gold</item>
    </style>

    <!-- Accent Button - Gold stroke and text -->
    <style name="Widget.Tleilax.Button.Accent" parent="Widget.Tleilax.Button">
        <item name="strokeColor">@color/accent_gold</item>
        <item name="android:textColor">@color/accent_gold</item>
    </style>

    <!-- Pill Button for animal selection -->
    <style name="Widget.Tleilax.Button.Pill" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="rippleColor">@color/accent_gold</item>
    </style>

    <!-- Square emoji button -->
    <style name="Widget.Tleilax.Button.Square" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="rippleColor">@color/accent_gold</item>
    </style>

    <!-- Segmented Button for Speed Control -->
    <style name="Widget.Tleilax.Button.Segment" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="rippleColor">@color/accent_gold</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.Tleilax.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/bg_surface</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="itemRippleColor">@color/accent_gold</item>
        <item name="labelVisibilityMode">unlabeled</item>
        <item name="itemPaddingTop">4dp</item>
        <item name="itemPaddingBottom">4dp</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.Tleilax.Nav.Active</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.Tleilax.Nav.Inactive</item>
    </style>

    <style name="TextAppearance.Tleilax.Nav.Active" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/accent_gold</item>
    </style>

    <style name="TextAppearance.Tleilax.Nav.Inactive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/text_muted</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.Tleilax.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Section Title -->
    <style name="TextAppearance.Tleilax.SectionTitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/accent_gold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Body Text -->
    <style name="TextAppearance.Tleilax.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Muted/Caption Text -->
    <style name="TextAppearance.Tleilax.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
</resources>
