<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            style="@style/TextAppearance.Tleilax.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="World" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Grid size"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"
            android:textSize="13sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_grid_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:thumbColor="@color/accent_gold"
            app:trackColorActive="@color/accent_gold"
            app:trackColorInactive="@color/border_subtle"
            android:valueFrom="10"
            android:valueTo="40"
            android:stepSize="1"
            android:value="20" />

        <TextView
            style="@style/TextAppearance.Tleilax.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Population" />

        <!-- Population sliders -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Wolves"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"
            android:textSize="13sp" />
        <com.google.android.material.slider.Slider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            android:value="5"
            app:thumbColor="@color/accent_gold"
            app:trackColorActive="@color/accent_gold"
            app:trackColorInactive="@color/border_subtle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Rabbits"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"
            android:textSize="13sp" />
        <com.google.android.material.slider.Slider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            android:value="20"
            app:thumbColor="@color/accent_gold"
            app:trackColorActive="@color/accent_gold"
            app:trackColorInactive="@color/border_subtle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset_defaults"
            style="@style/Widget.Tleilax.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:layout_marginBottom="36dp"
            android:text="Reset to defaults" />

    </LinearLayout>
</ScrollView>
