<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <TextView
        android:id="@+id/stats_label"
        style="@style/TextAppearance.Tleilax.SectionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:text="Population"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <HorizontalScrollView
        android:id="@+id/graph_toggle_scroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="20dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stats_label">

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/graph_toggle_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:checkedButton="@id/btn_top_species"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_top_species"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top 5"
                android:textAllCaps="false"
                android:textColor="#E7C76A"
                app:backgroundTint="@color/bg_surface"
                app:strokeColor="#E7C76A" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_all_species"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:textAllCaps="false"
                android:textColor="#E7C76A"
                app:backgroundTint="@color/bg_surface"
                app:strokeColor="#E7C76A" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_animals_only"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Animals"
                android:textAllCaps="false"
                android:textColor="#E7C76A"
                app:backgroundTint="@color/bg_surface"
                app:strokeColor="#E7C76A" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_plants_only"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plants"
                android:textAllCaps="false"
                app:backgroundTint="@color/bg_surface"
                app:strokeColor="#E7C76A"
                android:textColor="#E7C76A" />

        </com.google.android.material.button.MaterialButtonToggleGroup>
    </HorizontalScrollView>

    <FrameLayout
        android:id="@+id/any_chart_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        android:background="@color/bg_surface"
        app:layout_constraintBottom_toTopOf="@id/summary_card"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/graph_toggle_scroll">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/canvas_border" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="sans-serif"
            android:text="Population chart"
            android:textColor="@color/text_muted"
            android:textSize="14sp" />
    </FrameLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/summary_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@color/border_subtle"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/text_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="Simulation running · 0 ticks"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
