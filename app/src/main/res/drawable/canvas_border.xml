<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/border_subtle" />
            <solid android:color="@android:color/transparent" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Top-Left Corner Accent -->
    <item android:width="16dp" android:height="2dp" android:gravity="top|start">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_gold" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:width="2dp" android:height="16dp" android:gravity="top|start">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_gold" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Bottom-Right Corner Accent -->
    <item android:width="16dp" android:height="2dp" android:gravity="bottom|end">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_gold" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:width="2dp" android:height="16dp" android:gravity="bottom|end">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_gold" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
