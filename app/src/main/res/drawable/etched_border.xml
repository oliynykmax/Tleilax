<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/border_etched" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Corner Accents (Subtle "L" shapes) -->
    <item android:width="8dp" android:height="2dp" android:gravity="top|start">
        <shape android:shape="rectangle"><solid android:color="@color/accent_spice_gold" /></shape>
    </item>
    <item android:width="2dp" android:height="8dp" android:gravity="top|start">
        <shape android:shape="rectangle"><solid android:color="@color/accent_spice_gold" /></shape>
    </item>

    <item android:width="8dp" android:height="2dp" android:gravity="bottom|end">
        <shape android:shape="rectangle"><solid android:color="@color/accent_spice_gold" /></shape>
    </item>
    <item android:width="2dp" android:height="8dp" android:gravity="bottom|end">
        <shape android:shape="rectangle"><solid android:color="@color/accent_spice_gold" /></shape>
    </item>
</layer-list>